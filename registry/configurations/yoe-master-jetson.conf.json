{
    "description": "Yoe Distribution - NVIDIA Jetson Orin boards",
    "sources": {
        "bitbake": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/bitbake",
                "branch": "master",
                "rev": "master"
            }
        },
        "openembedded-core": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/openembedded-core",
                "branch": "master",
                "rev": "master"
            }
        },
        "yoe-distro": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/yoe-distro",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-openembedded": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/meta-openembedded",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-clang": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/meta-clang",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-qt6": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/meta-qt6",
                "branch": "yoe/6.10",
                "rev": "yoe/6.10"
            }
        },
        "meta-tegra": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/meta-tegra",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-tegra-community": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/meta-tegra-community",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-swupdate": {
            "git-remote": {
                "uri": "https://github.com/yoedistro/meta-swupdate",
                "branch": "master",
                "rev": "master"
            }
        }
    },
    "bitbake-setup": {
        "configurations": [
            {
                "bb-layers": [
                    "yoe-distro/sources/meta-yoe",
                    "meta-qt6",
                    "meta-openembedded/meta-filesystems",
                    "meta-openembedded/meta-multimedia",
                    "meta-openembedded/meta-networking",
                    "meta-openembedded/meta-oe",
                    "meta-openembedded/meta-perl",
                    "meta-openembedded/meta-python",
                    "openembedded-core/meta"
                ],
                "configurations": [
                    {
                        "name": "jetson-agx-orin-devkit",
                        "description": "Yoe Distribution for NVIDIA Jetson AGX Orin Developer Kit",
                        "setup-dir-name": "yoe-jetson-agx-orin-devkit",
                        "oe-fragments": [
                            "meta-yoe/projects/jetson-agx-orin-devkit"
                        ],
                        "bb-layers": [
                            "meta-tegra",
                            "meta-tegra-community",
                            "meta-swupdate"
                        ]
                    },
                    {
                        "name": "jetson-agx-orin-devkit-with-sstate",
                        "description": "Yoe Distribution for NVIDIA Jetson AGX Orin Developer Kit with internet sstate mirror acceleration. Note: hit rates may be low as Yoe uses DISTRO=yoe and Clang rather than the standard Yocto/GCC configuration.",
                        "setup-dir-name": "yoe-jetson-agx-orin-devkit",
                        "oe-fragments": [
                            "meta-yoe/projects/jetson-agx-orin-devkit",
                            "core/yocto/sstate-mirror-cdn"
                        ],
                        "bb-layers": [
                            "meta-tegra",
                            "meta-tegra-community",
                            "meta-swupdate"
                        ]
                    },
                    {
                        "name": "jetson-orin-nano-devkit",
                        "description": "Yoe Distribution for NVIDIA Jetson Orin Nano Developer Kit",
                        "setup-dir-name": "yoe-$machine",
                        "oe-fragments": [
                            "meta-yoe/projects/jetson-orin-nano-common"
                        ],
                        "oe-fragments-one-of": {
                            "machine": {
                                "description": "Target machine",
                                "options": [
                                    {
                                        "name": "machine/jetson-orin-nano-devkit",
                                        "description": "Jetson Orin Nano Developer Kit (SD)"
                                    },
                                    {
                                        "name": "machine/jetson-orin-nano-devkit-nvme",
                                        "description": "Jetson Orin Nano Developer Kit (NVMe)"
                                    }
                                ]
                            }
                        },
                        "bb-layers": [
                            "meta-tegra",
                            "meta-tegra-community",
                            "meta-swupdate"
                        ]
                    },
                    {
                        "name": "jetson-orin-nano-devkit-with-sstate",
                        "description": "Yoe Distribution for NVIDIA Jetson Orin Nano Developer Kit with internet sstate mirror acceleration. Note: hit rates may be low as Yoe uses DISTRO=yoe and Clang rather than the standard Yocto/GCC configuration.",
                        "setup-dir-name": "yoe-$machine",
                        "oe-fragments": [
                            "meta-yoe/projects/jetson-orin-nano-common",
                            "core/yocto/sstate-mirror-cdn"
                        ],
                        "oe-fragments-one-of": {
                            "machine": {
                                "description": "Target machine",
                                "options": [
                                    {
                                        "name": "machine/jetson-orin-nano-devkit",
                                        "description": "Jetson Orin Nano Developer Kit (SD)"
                                    },
                                    {
                                        "name": "machine/jetson-orin-nano-devkit-nvme",
                                        "description": "Jetson Orin Nano Developer Kit (NVMe)"
                                    }
                                ]
                            }
                        },
                        "bb-layers": [
                            "meta-tegra",
                            "meta-tegra-community",
                            "meta-swupdate"
                        ]
                    }
                ]
            }
        ]
    },
    "version": "1.0"
}
