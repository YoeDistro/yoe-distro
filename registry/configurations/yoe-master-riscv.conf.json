{
    "description": "Yoe Distribution - RISC-V boards",
    "sources": {
        "bitbake": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/bitbake",
                "branch": "master",
                "rev": "master"
            }
        },
        "openembedded-core": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/openembedded-core",
                "branch": "master",
                "rev": "master"
            }
        },
        "yoe-distro": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/yoe-distro",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-openembedded": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/meta-openembedded",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-clang": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/meta-clang",
                "branch": "master",
                "rev": "master"
            }
        },
        "meta-qt6": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/meta-qt6",
                "branch": "yoe/6.10",
                "rev": "yoe/6.10"
            }
        },
        "meta-riscv": {
            "git-remote": {
                "uri": "https://github.com/YoeDistro/meta-riscv",
                "branch": "master",
                "rev": "master"
            }
        }
    },
    "bitbake-setup": {
        "configurations": [
            {
                "bb-layers": [
                    "yoe-distro/sources/meta-yoe",
                    "meta-clang",
                    "meta-qt6",
                    "meta-openembedded/meta-filesystems",
                    "meta-openembedded/meta-gnome",
                    "meta-openembedded/meta-initramfs",
                    "meta-openembedded/meta-multimedia",
                    "meta-openembedded/meta-networking",
                    "meta-openembedded/meta-oe",
                    "meta-openembedded/meta-perl",
                    "meta-openembedded/meta-python",
                    "meta-openembedded/meta-webserver",
                    "meta-openembedded/meta-xfce",
                    "openembedded-core/meta",
                    "meta-riscv"
                ],
                "configurations": [
                    {
                        "name": "nezha-d1",
                        "description": "Yoe Distribution for Allwinner Nezha D1",
                        "setup-dir-name": "yoe-nezha-d1",
                        "oe-fragments": [
                            "meta-yoe/projects/nezha-d1"
                        ]
                    },
                    {
                        "name": "nezha-d1-with-sstate",
                        "description": "Yoe Distribution for Allwinner Nezha D1 with internet sstate mirror acceleration. Note: hit rates may be low as Yoe uses DISTRO=yoe and Clang rather than the standard Yocto/GCC configuration.",
                        "setup-dir-name": "yoe-nezha-d1",
                        "oe-fragments": [
                            "meta-yoe/projects/nezha-d1",
                            "core/yocto/sstate-mirror-cdn"
                        ]
                    },
                    {
                        "name": "unleashed",
                        "description": "Yoe Distribution for SiFive HiFive Unleashed",
                        "setup-dir-name": "yoe-unleashed",
                        "oe-fragments": [
                            "meta-yoe/projects/unleashed"
                        ]
                    },
                    {
                        "name": "unleashed-with-sstate",
                        "description": "Yoe Distribution for SiFive HiFive Unleashed with internet sstate mirror acceleration. Note: hit rates may be low as Yoe uses DISTRO=yoe and Clang rather than the standard Yocto/GCC configuration.",
                        "setup-dir-name": "yoe-unleashed",
                        "oe-fragments": [
                            "meta-yoe/projects/unleashed",
                            "core/yocto/sstate-mirror-cdn"
                        ]
                    },
                    {
                        "name": "unmatched",
                        "description": "Yoe Distribution for SiFive HiFive Unmatched",
                        "setup-dir-name": "yoe-unmatched",
                        "oe-fragments": [
                            "meta-yoe/projects/unmatched"
                        ]
                    },
                    {
                        "name": "unmatched-with-sstate",
                        "description": "Yoe Distribution for SiFive HiFive Unmatched with internet sstate mirror acceleration. Note: hit rates may be low as Yoe uses DISTRO=yoe and Clang rather than the standard Yocto/GCC configuration.",
                        "setup-dir-name": "yoe-unmatched",
                        "oe-fragments": [
                            "meta-yoe/projects/unmatched",
                            "core/yocto/sstate-mirror-cdn"
                        ]
                    },
                    {
                        "name": "visionfive",
                        "description": "Yoe Distribution for StarFive VisionFive",
                        "setup-dir-name": "yoe-visionfive",
                        "oe-fragments": [
                            "meta-yoe/projects/visionfive"
                        ]
                    },
                    {
                        "name": "visionfive-with-sstate",
                        "description": "Yoe Distribution for StarFive VisionFive with internet sstate mirror acceleration. Note: hit rates may be low as Yoe uses DISTRO=yoe and Clang rather than the standard Yocto/GCC configuration.",
                        "setup-dir-name": "yoe-visionfive",
                        "oe-fragments": [
                            "meta-yoe/projects/visionfive",
                            "core/yocto/sstate-mirror-cdn"
                        ]
                    },
                    {
                        "name": "visionfive2",
                        "description": "Yoe Distribution for StarFive VisionFive 2",
                        "setup-dir-name": "yoe-visionfive2",
                        "oe-fragments": [
                            "meta-yoe/projects/visionfive2"
                        ]
                    },
                    {
                        "name": "visionfive2-with-sstate",
                        "description": "Yoe Distribution for StarFive VisionFive 2 with internet sstate mirror acceleration. Note: hit rates may be low as Yoe uses DISTRO=yoe and Clang rather than the standard Yocto/GCC configuration.",
                        "setup-dir-name": "yoe-visionfive2",
                        "oe-fragments": [
                            "meta-yoe/projects/visionfive2",
                            "core/yocto/sstate-mirror-cdn"
                        ]
                    }
                ]
            }
        ]
    },
    "version": "1.0"
}
